      "dtype": "int64",
      "purpose": "hospital admission identifier"
    },
    "stay_id": {
      "dtype": "int64",
      "purpose": "ICU stay identifier"
    }
  },
  "target_fields": {
    "crisis_label": {
      "dtype": "int8",
