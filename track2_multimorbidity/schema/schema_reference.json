    "glucose_mean": {
      "dtype": "float32",
      "unit": "mg/dL",
      "valid_range": [
        40,
        500
      ],
      "missing_strategy": "median_impute",
      "source": "labevents itemid 50931 or chartevents itemid 225664"
    },
    "glucose_min": {
      "dtype": "float32",
      "unit": "mg/dL",
      "valid_range": [
        40,
        500
      ],
      "missing_strategy": "median_impute",
      "source": "labevents itemid 50931 or chartevents itemid 225664"
    },
    "glucose_max": {
      "dtype": "float32",
      "unit": "mg/dL",
      "valid_range": [
        40,
        500
      ],
      "missing_strategy": "median_impute",
      "source": "labevents itemid 50931 or chartevents itemid 225664"
    },
    "glucose_std": {
      "dtype": "float32",
      "unit": "mg/dL",
      "valid_range": [
