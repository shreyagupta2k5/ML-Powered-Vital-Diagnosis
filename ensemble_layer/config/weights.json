{
  "track_weights": {
    "track1_eicu": 0.45,
    "track2_multimorbidity": 0.30,
    "track3_vitaldb": 0.25
  },
  "track3_aggregation": {
    "method": "max",
    "description": "Use max probability among hypotension/tachycardia/low_spo2 for Track 3 score"
  },
  "risk_tiers": {
    "CRITICAL": {"min": 0.85, "max": 1.0, "action": "IMMEDIATE_ESCALATION"},
    "HIGH": {"min": 0.60, "max": 0.85, "action": "IMMEDIATE_REVIEW"},
    "MODERATE": {"min": 0.30, "max": 0.60, "action": "MONITOR_CLOSELY"},
    "LOW": {"min": 0.0, "max": 0.30, "action": "ROUTINE_CARE"}
  },
  "conflict_resolution": {
    "rule": "highest_risk_wins",
    "description": "If tracks disagree, use the highest risk tier among them"
  }
}